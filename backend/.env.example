PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=phr_db
DB_USER=phr_user
DB_PASSWORD=phr_password_change_me
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# Encryption
ENCRYPTION_KEY=32_char_encryption_key_here_xxxx

# File Upload
UPLOAD_MAX_SIZE_MB=20
UPLOADS_PATH=./uploads

# Firebase FCM (for push notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Claude API (for HealthBot AI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenFDA (drug interactions)
OPENFDA_API_KEY=your_openfda_api_key

# Allowed Origins
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000

# ABDM / ABHA (Ayushman Bharat Digital Mission)
ABDM_CLIENT_ID=your_abdm_client_id_here
ABDM_CLIENT_SECRET=your_abdm_client_secret_here
ABDM_GATEWAY_URL=https://dev.abdm.gov.in/gateway
ABHA_BASE_URL=https://abhasbx.abdm.gov.in/abha/api/v3
# Webhook callback base (use ngrok for local sandbox testing)
BACKEND_URL=https://your-backend-url.com

# Logging
LOG_LEVEL=info

# ── Exotel (SMS + WhatsApp + IVR — single Indian provider) ───────────────
# SID and Token from https://my.exotel.com → Settings → API
EXOTEL_SID=your_exotel_account_sid
EXOTEL_TOKEN=your_exotel_api_token
# Your Exotel virtual number for SMS / IVR (E.164)
EXOTEL_VIRTUAL_NUMBER=+91XXXXXXXXXX
# Your Exotel WhatsApp-enabled number (provisioned in Exotel dashboard)
EXOTEL_WHATSAPP_NUMBER=+91XXXXXXXXXX
# Webhook URLs to configure in Exotel dashboard:
#   SMS inbound   → https://api.inferapp.online/webhook/exotel/sms
#   WhatsApp      → https://api.inferapp.online/webhook/exotel/whatsapp
#   Voice (IVR)   → https://api.inferapp.online/webhook/exotel/voice
#   Status        → https://api.inferapp.online/webhook/exotel/status

# ── Meta WhatsApp Business Cloud API ──────────────────────────────────────
# From Facebook Developer Console → Your App → WhatsApp → API Setup
# Permanent access token (or system user token for production)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_permanent_access_token
# Phone Number ID (shown on API Setup page — NOT the phone number itself)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# App Secret (App Dashboard → Settings → Basic → App Secret)
WHATSAPP_APP_SECRET=your_app_secret_here
# Verify Token — any random string YOU choose; paste the same value in the
# Facebook Developer Console when configuring the webhook
WHATSAPP_VERIFY_TOKEN=infer_whatsapp_webhook_2025

# Webhook URLs to paste in Facebook Developer Console:
#   Callback URL  → https://api.inferapp.online/webhook/whatsapp
#   Verify Token  → (value of WHATSAPP_VERIFY_TOKEN above)
#   Subscribe to: messages, message_deliveries, message_reads

# ── SMSCountry (OTP + Notifications) ─────────────────────────────────────
# API key and URL from https://www.smscountry.com/restapidoc.html
SMS_API_URL=https://api.smscountry.com/v0.1/Send
SMS_API_KEY=your_smscountry_api_key_here
SMS_SENDER_ID=NOUSHL

# Template IDs from SMSCountry Dashboard → Templates
SMS_TEMPLATE_OTP=1207178211673331606
SMS_TEMPLATE_CARE_CONTEXT=your_care_context_template_id
SMS_TEMPLATE_ABHA_LINKING=your_abha_linking_template_id
SMS_TEMPLATE_APPOINTMENT=your_appointment_template_id
SMS_TEMPLATE_CHECK_IN=your_check_in_template_id

# ── Gemini AI (Google Generative AI) ─────────────────────────────────────
# API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
