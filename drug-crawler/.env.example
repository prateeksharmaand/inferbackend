# ── PostgreSQL (same DB as existing Infer backend) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://phr_user:<password>@localhost:5432/phr_db
# Sync URL used by Alembic only
DATABASE_SYNC_URL=postgresql+psycopg2://phr_user:<password>@localhost:5432/phr_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ── Eka Care API ──────────────────────────────────────────────────────────────
EKA_BASE_URL=https://mdb.eka.care
EKA_CID=your_cid_here
EKA_DOCID=your_docid_here

# Cookie rotation: JSON array of cookie strings, or a single cookie string
EKA_COOKIES='["session=abc123; auth=xyz", "session=def456; auth=uvw"]'

# Additional request headers (JSON object)
EKA_HEADERS='{"x-app-version": "1.0", "x-platform": "web"}'

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_CONCURRENCY=10
CRAWLER_MAX_DEPTH=6
CRAWLER_REQUEST_TIMEOUT=15
CRAWLER_RETRY_MAX=4
CRAWLER_RETRY_MIN_WAIT=1.0
CRAWLER_RETRY_MAX_WAIT=30.0
CRAWLER_API_LIMIT=8

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_COUNT=4

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO
