# === Groq API ===
GROQ_API_KEY=your_groq_api_key_here

# === SMTP + IMAP (Hostinger) ===
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@inferapp.online
SMTP_PASS=your_email_password_here
SMTP_FROM=support@inferapp.online
FROM_NAME=Infer EMR

# === Google Sheets CRM ===
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDS_FILE=google_creds.json

# === Agent limits ===
MAX_EMAILS_PER_RUN=50
DELAY_BETWEEN_EMAILS=30

# === Backend URL (for WA reply sync + email open tracking) ===
BACKEND_URL=https://api.inferapp.online

# === Meta WhatsApp (set in backend .env, not here — listed for reference) ===
# META_WA_VERIFY_TOKEN=your_random_verify_token
# META_WA_APP_SECRET=your_meta_app_secret
